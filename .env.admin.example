# ───────────────────────────────────────────────────────────
# Supabase admin automation — vytvoř kopii jako `.env.admin`
# (`.env.admin` je v .gitignore, never commitnuto).
# ───────────────────────────────────────────────────────────
#
# Tento soubor obsahuje pouze tokeny pro AUTOMATIZACI — Claude
# (nebo CI) je čte při běhu skriptů. Žádný hot reload.
#
# Co kde získat:
#   1. SUPABASE_ACCESS_TOKEN (Personal Access Token)
#      → https://supabase.com/dashboard/account/tokens
#      → "Generate new token", name="claude-automation"
#      → Scope: keep default (full account access)
#      → COPY token (zobrazí se jen jednou)
#
#   2. SUPABASE_SERVICE_ROLE_KEY (service_role JWT)
#      → https://supabase.com/dashboard/project/uusaczibimqvaazpaopy/settings/api
#      → "Project API keys" → "service_role" → reveal & copy
#      → ⚠ Tento klíč obchází RLS — chovej se k němu jako k root heslu
#
#   3. SUPABASE_PROJECT_REF
#      → V URL Supabase dashboardu (mezi /project/ a /settings/)
#      → Pro tenhle projekt = uusaczibimqvaazpaopy

SUPABASE_ACCESS_TOKEN=sbp_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
SUPABASE_SERVICE_ROLE_KEY=eyJhbGciOiJIUzI1NiIs...
SUPABASE_PROJECT_REF=uusaczibimqvaazpaopy
SUPABASE_URL=https://uusaczibimqvaazpaopy.supabase.co

# Pro AI integrační testy (verify:ai-curriculum)
ADMIN_EMAIL=eweigl@email.cz
ADMIN_PASSWORD=Admin123!
